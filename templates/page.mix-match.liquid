<div id="mix-match-app" class="mmapp">
  <div class="mmapp__card">
    <h2 class="mmapp__title">Mix &amp; Match (3 Items)</h2>
    <p class="mmapp__subtitle">Pick a top, then a bottom, then a sports bra.</p>

    <div class="mmapp__stepper" id="mmStepLabel"></div>

    <div class="mmapp__controls">
      <button type="button" class="mmapp__btn mmapp__btn--ghost" id="mmBackBtn" disabled>Back</button>
      <button type="button" class="mmapp__btn mmapp__btn--ghost" id="mmResetBtn">Reset</button>
    </div>

    <div class="mmapp__status" id="mmStatus" aria-live="polite"></div>

    <div class="mmapp__mobileFlow" id="mmMobileFlow" hidden>
      <div class="mmapp__mobileFlowInner" id="mmMobileFlowInner"></div>
    </div>

    <div class="mmapp__layout">
      <div class="mmapp__left">
        <div class="mmapp__filters" id="mmFilters" hidden>
          <div class="mmapp__filtersRow">
            <label class="mmapp__filterLabel">
              <span>Filter by color</span>
              <select id="mmFilterColor" class="mmapp__select">
                <option value="">All colors</option>
              </select>
            </label>

            <label class="mmapp__filterLabel">
              <span>Filter by size</span>
              <select id="mmFilterSize" class="mmapp__select">
                <option value="">All sizes</option>
              </select>
            </label>

            <div class="mmapp__filterLabel mmapp__filterLabel--action">
              <span aria-hidden="true">&nbsp;</span>
              <button type="button" id="mmClearFilters" class="mmapp__btn mmapp__btn--ghost">
                Clear filters
              </button>
            </div>
          </div>
        </div>

        <div class="mmapp__grid" id="mmGrid"></div>
      </div>

      <aside class="mmapp__aside" id="mmAside" hidden>
        <div class="mmapp__asideTitle">Your selections</div>
        <div id="mmAsideList"></div>

        <div class="mmapp__summary mmapp__summary--inAside" id="mmSummary" hidden>
          <h3 class="mmapp__h3">Your picks</h3>
          <ol class="mmapp__summaryList" id="mmSummaryList"></ol>

          <button type="button" class="mmapp__btn mmapp__btn--primary" id="mmAddToCartBtn">
            Add Mix &amp; Match to cart
          </button>

          <p class="mmapp__fineprint">
            This adds “Mix and Match” item to your cart, with the above items.
          </p>
        </div>
      </aside>
    </div>
  </div>
</div>

<style>
  :root{
    --mm-sticky-top:180px;
    --mm-sticky-gap:14px;
  }

  html, body { overscroll-behavior-y: contain; }

  .mmapp{max-width:1100px;margin:24px auto;padding:0 16px}
  .mmapp__card{border:1px solid rgba(0,0,0,.12);border-radius:14px;padding:18px}
  .mmapp__title{margin:0 0 6px;font-size:28px;line-height:1.1}
  .mmapp__subtitle{margin:0 0 14px;opacity:.8}
  .mmapp__stepper{margin:12px 0 16px;font-weight:700;font-size:22px;line-height:1.3}
  .mmapp__controls{display:flex;gap:10px;align-items:center;margin:8px 0 12px}
  .mmapp__status{margin:8px 0 14px;min-height:20px}

  .mmapp__mobileFlow{display:none}

  .mmapp__mobileFlowInner {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 18px 2px 0;
  }

  .mmapp__mobileFlowInner::-webkit-scrollbar {
    display: none;
  }

  .mmapp__mobileStep {
    flex: 0 0 auto;
    font-size: 11px;
    line-height: 1;
    padding: 8px 11px;
    white-space: nowrap;
  }

  .mmapp__mobileStep[data-state="done"]{
    border-color:#111;
    background:#111;
    color:#fff;
  }

  .mmapp__mobileStep[data-state="current"]{
    border-color:#111;
    box-shadow:0 0 0 2px rgba(0,0,0,.12);
  }

  .mmapp__mobileStepLabel{opacity:.72;margin-right:4px}

  .mmapp__layout{
    display:grid;
    grid-template-columns:1fr;
    gap:16px;
  }

  .mmapp__left{min-width:0}

  .mmapp__filters{
    margin:0 0 14px;
    padding:12px;
    border:1px solid rgba(0,0,0,.12);
    border-radius:12px;
    background:#fff;
  }

  .mmapp__filtersRow{
    display:flex;
    gap:10px;
    align-items:flex-end;
    flex-wrap:wrap;
  }

  .mmapp__filterLabel{
    display:flex;
    flex-direction:column;
    gap:6px;
    min-width:180px;
    margin:0;
    flex:1 1 180px;
  }

  .mmapp__filterLabel span{
    font-size:13px;
    font-weight:700;
    line-height:16px;
    margin:0;
    display:flex;
    align-items:center;
  }

  .mmapp__filterLabel--action{flex:0 0 auto}

  .mmapp__filters .mmapp__select{
    width:100%;
    height:44px;
    min-height:44px;
    margin:0;
    padding:0 12px;
    border-radius:10px;
    border:1px solid rgba(0,0,0,.2);
    background:#fff;
    box-sizing:border-box;
    line-height:normal;
    appearance:auto;
  }

  #mmClearFilters,
  #mmClearFilters.mmapp__btn,
  #mmClearFilters.mmapp__btn--ghost{
    height:44px;
    min-height:44px;
    margin:0 !important;
    padding:0 12px !important;
    border-radius:10px;
    box-sizing:border-box;
    line-height:normal;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    align-self:flex-end;
    white-space:nowrap;
  }

  .mmapp__grid{
    display:grid;
    grid-template-columns:repeat(1,minmax(0,1fr));
    gap:12px;
  }

  @media (min-width:720px){
    .mmapp__grid{grid-template-columns:repeat(2,minmax(0,1fr))}
  }

  @media (min-width:1024px){
    .mmapp__grid{grid-template-columns:repeat(3,minmax(0,1fr))}
  }

  @media (min-width:960px){
    .mmapp__layout{
      grid-template-columns:minmax(0,1fr) 320px;
      align-items:start;
    }

    .mmapp__aside{
      position:sticky;
      top:var(--mm-sticky-top);
      max-height:calc(100vh - var(--mm-sticky-top) - var(--mm-sticky-gap));
      overflow:auto;
      overscroll-behavior:contain;
    }
  }

  @media (max-width:959.98px){
    .mmapp__aside{
      position:static;
      max-height:none;
      overflow:visible;
    }
  }

  .mmapp__item{
    border:1px solid rgba(0,0,0,.12);
    border-radius:12px;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    background:#fff;
    min-width:0;
  }

  .mmapp__imgWrap{
    position:relative;
    width:100%;
    padding-top:150%;
    background:rgba(0,0,0,.03);
    overflow:hidden;
    display:block;
    cursor:pointer;
  }

  .mmapp__img{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    object-fit:cover;
    opacity:1;
  }

  .mmapp__body{
    padding:12px;
    display:flex;
    flex-direction:column;
    gap:10px;
    flex:1;
    min-width:0;
  }

  .mmapp__name{
    margin:0;
    font-size:16px;
    line-height:1.25;
    min-height:calc(1.25em * 2 + 8px);
    max-height:calc(1.25em * 2 + 8px);
    overflow:hidden;
  }

  .mmapp__price{margin:0;opacity:.8}
  .mmapp__select{width:100%;padding:10px;border-radius:10px;border:1px solid rgba(0,0,0,.2);background:#fff}
  .mmapp__btn{padding:10px 12px;border-radius:10px;border:1px solid rgba(0,0,0,.2);background:#fff;cursor:pointer}
  .mmapp__btn[disabled]{opacity:.5;cursor:not-allowed}
  .mmapp__summary{margin-top:18px;border-top:1px solid rgba(0,0,0,.12);padding-top:14px}

  .mmapp__summary--inAside{
    margin-top:14px;
    padding-top:14px;
    border-top:1px solid rgba(0,0,0,.12);
  }

  .mmapp__summary--inAside .mmapp__summaryList{
    margin:0 0 12px;
    padding-left:18px;
  }

  .mmapp__summary--inAside .mmapp__btn--primary{width:100%}

  .mmapp__h3{margin:0 0 10px}
  .mmapp__summaryList{margin:0 0 12px;padding-left:18px}
  .mmapp__fineprint{margin:10px 0 0;opacity:.75;font-size:13px}

  .mmapp__btn--ghost{
    position:relative;
    overflow:hidden;
    background:transparent;
    color:#111;
    border-color:rgba(0,0,0,.25);
    transition:color 180ms ease,border-color 180ms ease;
    isolation:isolate;
  }

  .mmapp__btn--ghost::before{
    content:"";
    position:absolute;
    inset:0;
    background:#111;
    transform:translate(55%,55%) rotate(-25deg) scale(1.6);
    transform-origin:bottom right;
    clip-path:polygon(100% 100%,100% 100%,100% 100%,100% 100%);
    transition:clip-path 260ms ease,transform 260ms ease;
    z-index:-1;
  }

  .mmapp__btn--ghost:hover,
  .mmapp__btn--ghost:focus-visible{
    color:#fff;
    border-color:#111;
  }

  .mmapp__btn--ghost:hover::before,
  .mmapp__btn--ghost:focus-visible::before{
    clip-path:polygon(0 0,100% 0,100% 100%,0 100%);
    transform:translate(0,0) rotate(0deg) scale(1);
  }

  .mmapp__btn--ghost[disabled]::before{content:none}

  .mmapp__btn--primary{
    position:relative;
    overflow:hidden;
    background:#fff;
    color:#111;
    border:1px solid rgba(0,0,0,.25);
    isolation:isolate;
    transition:color 180ms ease,border-color 180ms ease;
  }

  .mmapp__btn--primary::before{
    content:"";
    position:absolute;
    inset:0;
    background:#111;
    transform:translate(55%,55%) rotate(-25deg) scale(1.6);
    transform-origin:bottom right;
    clip-path:polygon(100% 100%,100% 100%,100% 100%,100% 100%);
    transition:clip-path 260ms ease,transform 260ms ease;
    z-index:-1;
  }

  .mmapp__btn--primary:hover,
  .mmapp__btn--primary:focus-visible{
    color:#fff;
    border-color:#111;
  }

  .mmapp__btn--primary:hover::before,
  .mmapp__btn--primary:focus-visible::before{
    clip-path:polygon(0 0,100% 0,100% 100%,0 100%);
    transform:translate(0,0) rotate(0deg) scale(1);
  }

  .mmapp__swatches{
    display:flex;
    flex-wrap:wrap;
    padding:4px 4px 8px;
    box-sizing:border-box;
    min-height:96px;
    max-height:96px;
    overflow:hidden;
    align-content:flex-start;
    margin:-4px 0 0 -4px;
  }

  .mmapp__swatches > .mmapp__swatch{
    margin:4px 0 0 4px;
  }

  .mmapp__swatch{
    width:38px;
    height:38px;
    padding:0;
    border-radius:50%;
    border:1px solid rgba(0,0,0,.25);
    background:#fff;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
    appearance:none;
    -webkit-appearance:none;
    flex:0 0 38px;
  }

  .mmapp__swatch img{
    width:100%;
    height:100%;
    object-fit:cover;
    border-radius:50%;
    display:block;
  }

  .mmapp__swatch[aria-pressed="true"]{
    border-color:#111;
    box-shadow:0 0 0 2px #111;
  }

/* begin Desktop only Safari */

.mm-desktop-safari .mmapp__swatch{
  position: relative;
  outline: none !important;
  -webkit-appearance: none;
  appearance: none;
}

.mm-desktop-safari .mmapp__swatch:focus,
.mm-desktop-safari .mmapp__swatch:focus-visible,
.mm-desktop-safari .mmapp__swatch:active{
  outline: none !important;
  box-shadow: none !important;
}

.mm-desktop-safari .mmapp__swatch::-moz-focus-inner{
  border: 0;
}

.mm-desktop-safari .mmapp__swatch::after{
  content:"";
  position:absolute;
  top:-2px;
  right:-2px;
  bottom:-2px;
  left:-2px;
  border-radius:50%;
  border:2px solid transparent;
  pointer-events:none;
  box-sizing:border-box;
}

.mm-desktop-safari .mmapp__swatch[aria-pressed="true"]{
  border-color:#111 !important;
  box-shadow:none !important;
}

.mm-desktop-safari .mmapp__swatch[aria-pressed="true"]::after{
  border-color:#111 !important;
}
/*end Desktop Safari fix only */

  .mmapp__helper{
    font-size:13px;
    line-height:1.25;
    opacity:.8;
    margin:0;
    min-height:calc(1.25em * 3 + 6px);
    max-height:calc(1.25em * 3 + 6px);
    overflow:hidden;
  }

  .mmapp__chosenColor{font-weight:700;margin-left:6px}

  .mmapp__aside{
    width:auto;
    border:1px solid rgba(0,0,0,.12);
