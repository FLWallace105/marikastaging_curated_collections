{% comment %}
** Main blog page - default view **
- Template section
- Uses blocks
{% endcomment %}

{% if section.settings.image != nil %}
  <header class="banner center page_banner dark-overlay-{{ section.settings.image_darken }}">
    <img  src="{{ section.settings.image | img_url: '100x' }}"
          alt="{% if section.settings.image.alt != blank %}{{ section.settings.image.alt }}{% else %}{{ blog.title | escape }}{% endif %}"
          class="lazyload {{ settings.image_loading_style }}"
          data-src="{{ section.settings.image | img_url: '1400x' }}"
          sizes="100vw"
          srcset="{{ section.settings.image | img_url: '480x' }} 480w,
                  {{ section.settings.image | img_url: '765x' }} 765w,
                  {{ section.settings.image | img_url: '1400x' }} 1400w,
                  {{ section.settings.image | img_url: '2048x' }} 2048w"
           />
  
	</header>
 	{% if section.settings.maintitle %}
        <div class="main-header">
          {% if section.settings.subtitle %}
          <p class="subtitle">{{ section.settings.subtitle }}</p>
          {% endif %}
          <h1 class="headline">{{ section.settings.maintitle }}</h1>
        </div>
  	{% endif %}
    
{% endif %}
<a name="pagecontent" id="pagecontent"></a>

<div class="container main content">

{% paginate blog.articles by section.settings.blog_posts_per_page %}
  <div class="blog-header clearfix">
    {% unless section.settings.image != nil %}
      <div class="eight columns">
          {% if current_tags %}
            <h1 class="blog-title blog-tags--true">
              <a href="/blogs/{{ blog.handle }}/tagged/{{ current_tags | handleize }}" title="{{ blog.title | escape }}">{{ current_tags }}</a>
            </h1>
          {% else %}
            <h1 class="blog-title">
              {{ blog.title }}
            </h1>
            {% if section.settings.subtitle %}
              <p class="subtitle">{{ section.settings.subtitle }}</p>
            {% endif %}
          {% endif %}
        </h1>

      </div>
    {% endunless %}

    <div class="eight columns section_select {% if section.settings.image != nil %}offset-by-eight{% endif %}">
      {% if section.settings.blog_tags %}
          <select name="tag_filter" id="blog_filter" class="blog_filter">
            <option {% unless current_tags %}selected="selected"{% endunless %} value="{{ blog.url }}">{{ 'blogs.general.view_all' | t }}</option>
            {% for tag in blog.all_tags %}
              <option {% if current_tags contains tag %}selected="selected"{% endif %} value="/blogs/{{ blog.handle }}/tagged/{{ tag | handleize }}">{{ tag }}</option>
            {% endfor %}
          </select>
      {% endif %}
    </div>
    {% unless section.settings.image != nil %}
      <div class="sixteen columns">
        <div class="feature_divider"></div>
      </div>
    {% endunless %}
  </div>

  {% comment %}Check to see if sidebar should be enabled{% endcomment %}
  {% if section.blocks.size > 0 %}
    {% assign sidebar = true %}
  {% else %}
    {% assign sidebar = false %}
  {% endif %}


  <div class="{% if sidebar %}offset-by-one eleven{% else %}sixteen{% endif %} columns">
    {% for article in blog.articles %}
      {% if section.settings.blog_posts_per_row == "1" %}
        {% if article.image %}
          <div class="article_image">
            <a href="{{ article.url }}" title="{{ article.title | escape }}">
              <img  src="{{ article.image | img_url: '100x' }}"
                    class="lazyload {{ settings.image_loading_style }}"
                    alt="{% if article.image.alt != blank %}{{ article.image.alt }}{% else %}{{ article.title | escape }}{% endif %}"
                    style="/*max-width: {{- article.image.width -}}px*/"
                    data-sizes="auto"
                    data-src="{{ article.image | img_url: '780x' }}"
                    data-srcset="   {{ article.image | img_url: '300x' }} 300w,
                                    {{ article.image | img_url: '400x' }} 400w,
                                    {{ article.image | img_url: '500x' }} 500w,
                                    {{ article.image | img_url: '600x' }} 600w,
                                    {{ article.image | img_url: '780x' }} 780w"
                    />
            </a>
          </div>
 		<div class="article">
        
        {% endif %}
        {% else %}
       	{% if sidebar %}
       <div class="article">
           {% endif %}
			<h4 class="blog-h2"><a href="{{ article.url }}">{{ article.title }}</a></h4>
           {% if article.image %}
           <a href="{{ article.url }}" title="{{ article.title | escape }}">
             <img  src="{{ article.image | img_url: '700x' }}"

                  class="lazyload {{ settings.image_loading_style }}"
                  alt="{% if article.image.alt != blank %}{{ article.image.alt }}{% else %}{{ article.title | escape }}{% endif %}"
                  style="/*max-width: {{- article.image.width -}}px*/"
                  data-sizes="auto"
                  data-src="{{ article.image | img_url: '780x' }}"
                  data-srcset="{{ article.image | img_url: '300x' }} 300w,
                               {{ article.image | img_url: '400x' }} 400w,
                               {{ article.image | img_url: '500x' }} 500w,
                               {{ article.image | img_url: '600x' }} 600w,
                               {{ article.image | img_url: '780x' }} 780w"
                  />
           </a>
           {% endif %}
        {% endif %}

        <p class="blog_meta">
          {% comment %}{% if section.settings.blog_author %}
            <span>{{ 'blogs.article.by_author' | t: author: article.author }}</span>
          {% endif %}

          {% if section.settings.blog_date %}
            <span>{{ article.published_at | date: format: "month_day_year" }}</span>
          {% endif %}{% endcomment %}

          {% if section.settings.blog_comment_count %}
            {% if settings.disqus_enabled %}
              <span>
                <a href="{{ article.url }}#disqus_thread" data-disqus-identifier="{{ article.id }}" class="disqus-comment-count">{{ 'blogs.counts.comments_with_count' | t: count: 0 }}</a>
              </span>
            {% elsif article.comments_enabled? and article.comments_count > 0 %}
              <span>
                <a href="{{ article.url }}#comments">{{ 'blogs.counts.comments_with_count' | t: count: article.comments_count }}</a>
              </span>
            {% endif %}
          {% endif %}
        </p>
        {% if section.settings.blog_tags %}
          <div class="blog_meta tags">
            {% for tag in article.tags %}
              <span><a href="{{ shop.url }}/blogs/{{ blog.handle }}/tagged/{{ tag | handleize }}" title="{{ blog.title }} {{ 'blogs.general.tagged' | t }} {{ tag | escape }}">{{ tag }}</a></span>
            {% endfor %}
          </div>
        {% endif %}

        {% if article.excerpt != blank %}
          <div class="excerpt"> {{ article.excerpt }}</div>
        {% endif %}
        {% if section.settings.read_more_link %}
          <a href="{{ article.url }}" title="{{ article.title | escape }}" class="{% if settings.read_more_style == 'button' %}action_button continue-button{% else %}{% endif %}">{{ 'blogs.general.continue_reading_html' | t }}</a>
        {% endif %}
      </div>
                    
      <br class="clear" />
                    
    {% endfor %}
  </div>

  {% include "blog-sidebar", blog_handle: blog.handle %}

  <br class="clear" />
  <div class="sixteen columns">
    {% include 'pagination' %}
  </div>
{% endpaginate %}
    <div class="sixteen columns">
    {% if section.settings.display_recently_viewed %}
        {% include 'recently-viewed' %}
    {% endif %}
  </div>
    
</div>
<style>

</style>
  


{% schema %}

{
  "name": "Blog",
  "class": "blog-section",
  "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Banner image",
        "info": "1600 x 600px recommended"
      },
      {
        "type": "checkbox",
        "id": "image_darken",
        "label": "Darken banner image",
        "default": false
      },
      {
        "type": "text",
        "id": "maintitle",
        "label": "Heading",
        "default": "Heading"
      },
      {
        "type": "text",
        "id": "subtitle",
        "label": "Subtitle",
        "default": "Subtitle"
      },
      {
       "type": "select",
       "id": "blog_posts_per_page",
       "label": "Blog posts per page",
       "options": [
         {
           "value": "3",
           "label": "3"
         },
         {
           "value": "4",
           "label": "4"
         },
         {
           "value": "6",
           "label": "6"
         },
         {
           "value": "8",
           "label": "8"
         }
       ],
       "default": "4"
      },
    {
     "type": "checkbox",
     "id": "blog_tags",
     "label": "Show blog post tags"
    },
    {
     "type": "checkbox",
     "id": "blog_author",
     "label": "Show author"
    },

    {
     "type": "checkbox",
     "id": "blog_date",
     "label": "Show date",
     "default": true
    },
    {
     "type": "checkbox",
     "id": "blog_comment_count",
     "label": "Show comment count",
     "default": true
    },
    {
     "type": "checkbox",
     "id": "read_more_link",
     "label": "Show continue reading link for blog post excerpts",
     "default": true
    },
	{
      "type": "header",
      "content": "Recently viewed products"
    },
    {
      "type": "paragraph",
      "content": "To test the recently viewed products, view your online store outside of the Editor and visit multiple product pages ([?](https:\/\/help.outofthesandbox.com\/hc\/en-us\/articles\/115008765228))"
    },
    {
      "type": "checkbox",
      "id": "display_recently_viewed",
      "label": "Show recently viewed products",
      "default": false
    },
	{
      "type": "text",
      "id": "rv_title",
      "label": "Title",
      "default": "Recently Viewed Items"
    },
    {
      "type": "radio",
      "id": "rv_products_style",
      "label": "Layout",
      "default": "grid",
      "options": [
        {
          "value": "slider",
          "label": "Slider"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ]
    },
    {
      "type": "select",
      "id": "rv_max_display",
      "label": "Products limit",
      "default": "4",
      "options": [
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        },
        {
          "value": "8",
          "label": "8"
        },
        {
          "value": "9",
          "label": "9"
        },
		{
          "value": "12",
          "label": "12"
        }
      ]
    },
    {
      "type": "select",
      "id": "rv_per",
      "label": "Products per row",
      "default": "4",
		"options": [
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
	  ]
    },
    {
     "type": "header",
     "content": "Sidebar"
    },
    {
      "type": "paragraph",
      "content": "Create a sidebar by adding content blocks."
    },
    {
      "type": "checkbox",
      "id": "toggle",
      "label": "Toggle sidebar content"
    }
  ],
  "blocks": [
    {
      "type": "post_tags",
      "name": "Blog post tags",
      "limit": 1
    },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "custom_menu_linklist",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Text area can be used for details about blog authors or general information.</p>"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image and Caption",
      "settings": [
		{
          "type": "text",
          "id": "image_heading",
          "label": "Image Heading",
          "default": "Heading here"
        },
        {
          "type": "text",
          "id": "image_caption",
          "label": "Image Caption",
          "default": "Caption here"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Sidebar image"
        },
		{
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter sign up form",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "newsletter_title",
          "label": "Heading",
          "default": "Subscribe"
        },
        {
          "type": "richtext",
          "id": "newsletter_text",
          "label": "Subheading",
          "default": "<p>Sign up to get the latest on sales, new releases and more …</p>"
        }
      ]
    },
    {
      "type": "page",
      "name": "Page",
      "settings": [
        {
          "type": "page",
          "id": "content_page",
          "label": "Page"
        }
      ]
    },    
    {
      "type": "recent_posts",
      "name": "Recent blog posts",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "blog_post_count",
          "label": "Display blog posts",
          "options": [
            {
              "value": "2",
              "label": "2"
            },
            {
              "value": "5",
              "label": "5"
            },
            {
              "value": "10",
              "label": "10"
            }
          ],
          "default": "10"
        }
      ]
    },    
    {
      "type": "search",
      "name": "Search form",
      "limit": 1
    }
  ]
}

{% endschema %}

